{
  "name": "cspr-sentinel",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "scripts": {
    "dev": "pnpm --filter @cspr-sentinel/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm -r lint",
    "security:scan": "node scripts/security-scan.mjs",
    "testnet:preflight": "node scripts/testnet-preflight.mjs",
    "wallets:generate": "cd apps/web && node scripts/generate-testnet-wallets.mjs",
    "wallets:fund-roles": "cd apps/web && node scripts/fund-testnet-roles.mjs",
    "contract:deploy:testnet": "./scripts/deploy-reputation-testnet.sh",
    "check": "pnpm typecheck && pnpm test && pnpm security:scan && pnpm build",
    "db:generate": "pnpm --filter @cspr-sentinel/core db:generate",
    "db:migrate": "pnpm --filter @cspr-sentinel/core db:migrate"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
